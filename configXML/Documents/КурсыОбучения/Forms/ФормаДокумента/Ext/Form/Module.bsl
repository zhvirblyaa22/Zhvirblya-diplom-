             
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Респондент = Пользователи.ТекущийПользователь();
		РежимАнкетирования = Перечисления.РежимыАнкетирования.Анкета;
		УстановитьОформлениеФормыПоРолям();
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Автор) Тогда
		Объект.Автор = Пользователи.ТекущийПользователь();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
    ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
    // Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	ЗаполнитьТаблицуФормыКартинкиТекстовыхБлоков();
	
	Респондент = Пользователи.ТекущийПользователь();
	РежимАнкетирования = Перечисления.РежимыАнкетирования.Анкета;
	УстановитьОформлениеФормыПоРолям();
	
	ОбновитьОтображениеЭлементовКурсаДляОбучающихся();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
    ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
    // Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "Запись_Анкета" ИЛИ ИмяСобытия = "Проведение_Анкета" Тогда
		ТаблицаАнкетРеспондента();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	АктуализироватьДанныеКартинокВРегистре(ТекущийОбъект.Ссылка, КартинкиТекстовыхБлоков.Выгрузить());
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	ЭтаФорма.Прочитать();
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.ПослеЗаписи(ЭтотОбъект, Объект, ПараметрыЗаписи);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	ОповеститьОбИзменении(Объект.Ссылка);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ФлагПредпросмотрТеорииПриИзменении(Элемент)
	ФлагПредпросмотрТеорииПриИзмененииНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПоказатьКартинку(Элемент, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	
	ПоказатьКартинкуАсинх(Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура ГруппаКурсДляОбучающихсяСтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	Если ТекущаяСтраница = Элементы.ГруппаПрактикаДляОбучающихсяСтраница Тогда
		ТаблицаАнкетРеспондента();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаАнкетПередНачаломИзменения(Элемент, Отказ)
	
	Отказ = Истина;
	
	ТекущиеДанные = Элементы.ТаблицаАнкет.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ТекущиеДанные.АнкетаОпрос) = Тип("ДокументСсылка.Анкета") Тогда
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("Ключ",ТекущиеДанные.АнкетаОпрос);
		СтруктураПараметров.Вставить("ТолькоФормаЗаполнения", Истина);
		СтруктураПараметров.Вставить("РежимАнкетирования", РежимАнкетирования);
		СтруктураПараметров.Вставить("Заголовок", ТекущиеДанные.Представление);
		ОткрытьФорму("Документ.Анкета.ФормаОбъекта", СтруктураПараметров, Элемент);
	ИначеЕсли ТипЗнч(ТекущиеДанные.АнкетаОпрос) = Тип("ДокументСсылка.НазначениеОпросов") Тогда
		СтруктураПараметров = Новый Структура;
		ЗначенияЗаполнения 	= Новый Структура;
		ЗначенияЗаполнения.Вставить("Респондент", Респондент);
		ЗначенияЗаполнения.Вставить("Опрос", ТекущиеДанные.АнкетаОпрос);
		ЗначенияЗаполнения.Вставить("РежимАнкетирования", РежимАнкетирования);
		СтруктураПараметров.Вставить("Заголовок", ТекущиеДанные.Представление);
		СтруктураПараметров.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
		СтруктураПараметров.Вставить("ТолькоФормаЗаполнения", Истина);
		ОткрытьФорму("Документ.Анкета.ФормаОбъекта", СтруктураПараметров, Элемент, ТекущиеДанные.Представление);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицФормы

&НаКлиенте
Процедура ТекстовыеБлокиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = ЭтаФорма.Элементы.ТекстовыеБлоки.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Открываем форму редактирования текстового блока.
	ПараметрыОткрытияФормы = Новый Структура();
	
	ПараметрыОткрытияФормы.Вставить("ИдентификаторТекстовогоБлока", ТекущиеДанные.ИдентификаторТекстовогоБлока);
	ПараметрыОткрытияФормы.Вставить("ЗаголовокТекстовогоБлока", ТекущиеДанные.ЗаголовокТекстовогоБлока);
	ПараметрыОткрытияФормы.Вставить("КурсОбученияСсылка", Объект.Ссылка);
	ПараметрыОткрытияФормы.Вставить("Текст", ТекущиеДанные.Текст);
	// Для помещения картинок во временное хранилище с ключом формы-владельца.
	ПараметрыОткрытияФормы.Вставить("УникальныйИдентификаторВладельца", ЭтаФорма.УникальныйИдентификатор);
	
	// Соберем данные картинки и передадим в форму редактирования.
	ОписаниеКартинки = ПолучитьСтруктуруОписанияКартинки();
	ПараметрыОтбора = Новый Структура("ИдентификаторТекстовогоБлока", ТекущиеДанные.ИдентификаторТекстовогоБлока);
	НайденныеСтроки = ЭтаФорма.КартинкиТекстовыхБлоков.НайтиСтроки(ПараметрыОтбора);
	Если НайденныеСтроки.Количество() > 0 Тогда
		ЗаполнитьЗначенияСвойств(ОписаниеКартинки, НайденныеСтроки[0]);
	КонецЕсли;
	ПараметрыОткрытияФормы.Вставить("ОписаниеКартинки", ОписаниеКартинки);
	
	ИмяПроцедуры = "ПослеЗавершенияРедактированияТекстовогоБлока";
	ДополнительныеПараметры = Новый Структура("ИдентификаторСтроки", ТекущиеДанные.ПолучитьИдентификатор());
	ОписаниеОповещения = Новый ОписаниеОповещения(ИмяПроцедуры, ЭтотОбъект, ДополнительныеПараметры);
	ОткрытьФорму("Документ.КурсыОбучения.Форма.ФормаРедактированияТекстовогоБлока", ПараметрыОткрытияФормы, 
		ЭтотОбъект,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры
	
&НаКлиенте
Процедура ПослеЗавершенияРедактированияТекстовогоБлока(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Объект.ТекстовыеБлоки.НайтиПоИдентификатору(ДополнительныеПараметры.ИдентификаторСтроки);
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СписокСвойств = "ЗаголовокТекстовогоБлока,Текст,ИдентификаторТекстовогоБлока";
	ЗаполнитьЗначенияСвойств(ТекущиеДанные, Результат, СписокСвойств);
	
	Если Результат.Свойство("ДанныеКартинки") Тогда
		АктуализироватьТаблицуКартинокТекстовыхБлоков(Результат.ДанныеКартинки, ДополнительныеПараметры.ИдентификаторСтроки);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Обновить(Команда)
	ТаблицаАнкетРеспондента();
КонецПроцедуры

&НаКлиенте
Процедура ПодтвердитьОзнакомление(Команда)
	
	ПодтвердитьОзнакомлениеНаСервере();
	Элементы.ГруппаКурсДляОбучающихсяСтраницы.ТекущаяСтраница = Элементы.ГруппаПрактикаДляОбучающихсяСтраница;
	
	ИмяПроцедуры = "ПослеНажатияНаУведомлениеОбУспешномОзнакомленииСТеорией";
	ОписаниеОповещения = Новый ОписаниеОповещения(ИмяПроцедуры, ЭтотОбъект);
	ПоказатьОповещениеПользователя("Теория изучена.", ОписаниеОповещения, 
		"Вернуться к теории.",, СтатусОповещенияПользователя.Информация);

КонецПроцедуры

&НаКлиенте
Процедура ПодтвердитьВыполнениеКурса(Команда)
	
	Если ПустаяСтрока(Элементы.ДекорацияДатаОзнакомления.Заголовок) Тогда
		ТекстПредупреждения = "Перед выполнением практической части требуется подтвердить ознакомление с теорией.
							  |Установите отметку ""Ознакомлен"" в нижней части вкладки ""Теория"".";
		ПоказатьПредупреждение(, ТекстПредупреждения,, "Ознакомьтесь с теорией");
		Элементы.ГруппаКурсДляОбучающихсяСтраницы.ТекущаяСтраница = Элементы.ГруппаТеорияДляОбучающихсяСтраница;
		Возврат;
	КонецЕсли;
	
	Отказ = Ложь;
	
	Если ТаблицаАнкет.Количество() <> 0 Тогда
		ТекстСообщенияПользователю = "Перед выполнением курса убедитесь, что все опросы пройдены.";
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщенияПользователю,, "ТаблицаАнкет",, Отказ);
	КонецЕсли;
	
	Если Объект.КомментарийОбучающегосяОбязателен = Истина И ПустаяСтрока(КомментарийОбучающегося) Тогда
		ТекстСообщенияПользователю = "Перед выполнением курса добавьте комментарий к выполнению.";
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщенияПользователю,, "КомментарийОбучающегося",, Отказ);
	КонецЕсли;
	
	Если Отказ = Истина Тогда
		Возврат;
	КонецЕсли;
	
	ПодтвердитьВыполнениеКурсаНаСервере();
	
	ИмяПроцедуры = "ПослеНажатияНаУведомлениеОВыполненииКурса";
	ОписаниеОповещения = Новый ОписаниеОповещения(ИмяПроцедуры, ЭтотОбъект);
	ПоказатьОповещениеПользователя("Курс пройден.", ОписаниеОповещения, 
		"Ожидайте результатов!",, СтатусОповещенияПользователя.Информация);
	
КонецПроцедуры

