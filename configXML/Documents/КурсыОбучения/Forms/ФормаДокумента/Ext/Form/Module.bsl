// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьТаблицуФормыКартинкиТекстовыхБлоков()

	РегистрСведенийМенеджер = РегистрыСведений.ДанныеКартинокТекстовыхБлоковКурсовОбучения;
	ДанныеКартинокКурса = РегистрСведенийМенеджер.ПолучитьДанныеКартинокПоКурсуОбучения(Объект.Ссылка);
	СтрокаНеограниченная = Новый ОписаниеТипов("Строка",,,, Новый КвалификаторыСтроки(0));
	ДанныеКартинокКурса.Колонки.Добавить("АдресКартинки", СтрокаНеограниченная);
	
	Для Каждого СтрокаТаблицы Из ДанныеКартинокКурса Цикл
		ЗначенияКлюча = Новый Структура("КурсОбучения,ИдентификаторТекстовогоБлока", 
			Объект.Ссылка, СтрокаТаблицы.ИдентификаторТекстовогоБлока);
		КлючЗаписи = РегистрСведенийМенеджер.СоздатьКлючЗаписи(ЗначенияКлюча);
		СтрокаТаблицы.АдресКартинки = ПолучитьНавигационнуюСсылку(КлючЗаписи, "ДанныеКартинки");
	КонецЦикла;
	
	ДанныеКартинокКурса.Колонки.Удалить("ДанныеКартинки");
	
	КартинкиТекстовыхБлоков.Загрузить(ДанныеКартинокКурса);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОформлениеФормыПоРолям()

	ОтображатьНастройкиКурса = Пользователи.РолиДоступны("ДобавлениеИзменениеКурсовОбучения");
	
	Элементы.ФормаЗаписать.Видимость 			= ОтображатьНастройкиКурса;
	Элементы.ГруппаНастройкаКурса.Видимость 	= ОтображатьНастройкиКурса;
	Элементы.ГруппаНастройкаКурса.Доступность 	= ОтображатьНастройкиКурса;
	Элементы.ГруппаКурсДляОбучающихся.Видимость 	= НЕ ОтображатьНастройкиКурса;
	Элементы.ГруппаКурсДляОбучающихся.Доступность 	= НЕ ОтображатьНастройкиКурса;
	
	Если ОтображатьНастройкиКурса Тогда
		
		УстановитьТекстКолонкиКартинкиТаблицыТекстовыхБлоков();
		
		Элементы.ПодтвердитьОзнакомление.Доступность = Ложь;
		Элементы.ПодтвердитьВыполнениеКурса.Доступность = Ложь;
		
	Иначе
		УстановитьДоступностьЭлементовНаОснованииПрогрессаВыполненияКурса();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьТекстКолонкиКартинкиТаблицыТекстовыхБлоков()

	Для Каждого СтрокаТаблицы Из Объект.ТекстовыеБлоки Цикл
		ПараметрыПоиска = Новый Структура("ИдентификаторТекстовогоБлока", СтрокаТаблицы.ИдентификаторТекстовогоБлока);
		НайденныеСтроки = КартинкиТекстовыхБлоков.НайтиСтроки(ПараметрыПоиска);
		ТекстИнформирования = ?(НайденныеСтроки.Количество() > 0, НайденныеСтроки[0].ИмяФайла, "Нет картинки");
		СтрокаТаблицы.Картинки = ТекстИнформирования;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура АктуализироватьТаблицуКартинокТекстовыхБлоков(ДанныеКартинки, ИдентификаторСтроки)

	НайденнаяСтрока = Объект.ТекстовыеБлоки.НайтиПоИдентификатору(ИдентификаторСтроки);
	ИдентификаторТекстовогоБлока = НайденнаяСтрока.ИдентификаторТекстовогоБлока;
	
	ПараметрыОтбора = Новый Структура("ИдентификаторТекстовогоБлока", ИдентификаторТекстовогоБлока);
	НайденныеСтроки = КартинкиТекстовыхБлоков.НайтиСтроки(ПараметрыОтбора);
	Если Не ПустаяСтрока(ДанныеКартинки.АдресКартинки) Тогда
		
		Если НайденныеСтроки.Количество() = 0 Тогда
			СтрокаДанныхКартинки = КартинкиТекстовыхБлоков.Добавить();
			СтрокаДанныхКартинки.ИдентификаторТекстовогоБлока = ИдентификаторТекстовогоБлока;
		Иначе
			СтрокаДанныхКартинки = НайденныеСтроки[0];
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(СтрокаДанныхКартинки, ДанныеКартинки, ПолучитьСписокСвойствСтруктурыОписанияКартинки());
		
	Иначе
		
		Если НайденныеСтроки.Количество() > 0 Тогда
			КартинкиТекстовыхБлоков.Удалить(НайденныеСтроки[0]);
		КонецЕсли;
		
	КонецЕсли;
	
	УстановитьТекстКолонкиКартинкиТаблицыТекстовыхБлоков();
	
КонецПроцедуры

&НаСервере
Процедура АктуализироватьДанныеКартинокВРегистре(КурсОбученияСсылка, ДанныеКартинокКурса)
	
	СтрокиУдалить = Новый Массив();
	
	ПараметрыОтбора = Новый Структура("ИдентификаторТекстовогоБлока");
	Для Каждого СтрокаТаблицы Из ДанныеКартинокКурса Цикл
		ПараметрыОтбора.ИдентификаторТекстовогоБлока = СтрокаТаблицы.ИдентификаторТекстовогоБлока;
		НайденныеСтроки = Объект.ТекстовыеБлоки.НайтиСтроки(ПараметрыОтбора);
		Если НайденныеСтроки.Количество() = 0 Тогда
			СтрокиУдалить.Добавить(СтрокаТаблицы);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого СтрокаУдалить Из СтрокиУдалить Цикл
		ДанныеКартинокКурса.Удалить(СтрокаУдалить);
	КонецЦикла;
	
	РегистрСведенийМенеджер = РегистрыСведений.ДанныеКартинокТекстовыхБлоковКурсовОбучения;
	РегистрСведенийМенеджер.АктуализироватьДанныеКартинокВРегистре(КурсОбученияСсылка, ДанныеКартинокКурса);
	
КонецПроцедуры

&НаСервере
Процедура ФлагПредпросмотрТеорииПриИзмененииНаСервере()
	
	Если ЭтаФорма.ФлагПредпросмотрТеории = 1 Тогда
		ОбновитьОтображениеЭлементовКурсаДляОбучающихся();
		Элементы.Переместить(Элементы.ГруппаТеорияДляОбучающихся, 
							 Элементы.ГруппаНастройкаТеория);
	Иначе
		Элементы.Переместить(Элементы.ГруппаТеорияДляОбучающихся, 
							 Элементы.ГруппаТеорияДляОбучающихсяСтраница);
	КонецЕсли;
	
	Элементы.НастройкаТекстовыхБлоков.Видимость = (ЭтаФорма.ФлагПредпросмотрТеории = 0);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьСтруктуруОписанияКартинки()
	
	Результат = Новый Структура();
	
	Результат.Вставить("АдресКартинки", 	"");
	Результат.Вставить("ИмяФайла", 			"");
	Результат.Вставить("РазмерФайла", 		"");
	Результат.Вставить("РасширениеФайла", 	"");
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьСписокСвойствСтруктурыОписанияКартинки()
	Возврат "АдресКартинки,ИмяФайла,РазмерФайла,РасширениеФайла";	
КонецФункции

&НаСервере
Процедура ОбновитьОтображениеЭлементовКурсаДляОбучающихся()
	
	ПрефиксШаблон 			= "Добавленный_";
	ШаблонЗаголовка 		= "ЗаголовокТекстовогоБлока_";
	ШаблонТекстовогоБлока 	= "ТекстовыйБлок_";
	ШаблонКартинки 			= "Картинка_";
	ШаблонГруппы 			= "ГруппаТекстовогоБлока_";
	ПрефиксПодчиненнойГруппы = "ПодГруппа_";
	
	ТипСтрокаНеогр = Новый ОписаниеТипов("Строка",,,, Новый КвалификаторыСтроки(0));
	Разделитель = ",";
	
	УдаляемыеРеквизиты = СтрРазделить(ЭтаФорма.ИменаПрограммноДобавленныхРеквизитов, Разделитель, Ложь);
	ДобавляемыеРеквизиты 			= Новый Массив();
	МассивИменДобавленныхРеквизитов = Новый Массив();
	МассивИменДобавленныхЭлементов  = Новый Массив();
	
	ПосадочнаяГруппа = Элементы.ГруппаТеорияДляОбучающихся;
	
	// Удалим старые элементы формы
	Для Каждого ИмяЭлемента Из СтрРазделить(ЭтаФорма.ИменаПрограммноДобавленныхЭлементов, Разделитель, Ложь) Цикл
		Элементы.Удалить(ПосадочнаяГруппа.ПодчиненныеЭлементы.Найти(ИмяЭлемента));
	КонецЦикла;
	
	Для Каждого СтрокаТаблицы Из Объект.ТекстовыеБлоки Цикл
		
		ПорядковыйНомер = СтрокаТаблицы.НомерСтроки;
		
		// Добавляем реквизит заголовка
		ИмяРеквизитаЗаголовка = ПрефиксШаблон + ШаблонЗаголовка + ПорядковыйНомер;
		РеквизитЗаголовка = Новый РеквизитФормы(ИмяРеквизитаЗаголовка, ТипСтрокаНеогр,, ИмяРеквизитаЗаголовка);
		ДобавляемыеРеквизиты.Добавить(РеквизитЗаголовка);
		МассивИменДобавленныхРеквизитов.Добавить(ИмяРеквизитаЗаголовка);
		
		// Добавляем реквизит текстового блока
		ИмяРеквизитаТекстовогоБлока = ПрефиксШаблон + ШаблонТекстовогоБлока + ПорядковыйНомер;
		РеквизитТекстовогоБлока = Новый РеквизитФормы(ИмяРеквизитаТекстовогоБлока, ТипСтрокаНеогр,, ИмяРеквизитаТекстовогоБлока);
		ДобавляемыеРеквизиты.Добавить(РеквизитТекстовогоБлока);
		МассивИменДобавленныхРеквизитов.Добавить(ИмяРеквизитаТекстовогоБлока);
		
		ПараметрыОтбора = Новый Структура("ИдентификаторТекстовогоБлока", СтрокаТаблицы.ИдентификаторТекстовогоБлока);
		НайденныеСтроки = КартинкиТекстовыхБлоков.НайтиСтроки(ПараметрыОтбора);
		Если НайденныеСтроки.Количество() > 0 Тогда
			// Добавляем реквизит картинки
			ИмяРеквизитаКартинки = ПрефиксШаблон + ШаблонКартинки + ПорядковыйНомер;
			РеквизитКартинки = Новый РеквизитФормы(ИмяРеквизитаКартинки, ТипСтрокаНеогр,, ИмяРеквизитаКартинки);
			ДобавляемыеРеквизиты.Добавить(РеквизитКартинки);
			МассивИменДобавленныхРеквизитов.Добавить(ИмяРеквизитаКартинки);
		КонецЕсли;
		
		// Создаем группу текстового блока
		ИмяЭлементаГруппы = ПрефиксШаблон + ШаблонГруппы + ПорядковыйНомер;
		ГруппаФормы = Элементы.Добавить(ИмяЭлементаГруппы, Тип("ГруппаФормы"), ПосадочнаяГруппа);
		ГруппаФормы.Вид                        = ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаФормы.Отображение                = ОтображениеОбычнойГруппы.Нет;
		ГруппаФормы.ОтображатьЗаголовок        = Ложь;
		ГруппаФормы.Группировка                = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		
		МассивИменДобавленныхЭлементов.Добавить(ИмяЭлементаГруппы);
		
	КонецЦикла;
	
	ЭтаФорма.ИменаПрограммноДобавленныхРеквизитов = СтрСоединить(МассивИменДобавленныхРеквизитов, Разделитель);
	ЭтаФорма.ИменаПрограммноДобавленныхЭлементов = СтрСоединить(МассивИменДобавленныхЭлементов, Разделитель);
	
	ЭтаФорма.ИзменитьРеквизиты(ДобавляемыеРеквизиты, УдаляемыеРеквизиты);
	
	// Заполним добавленные реквизиты формы значениями из строк таблицы
	Для Каждого СтрокаТаблицы Из Объект.ТекстовыеБлоки Цикл
		
		ИмяРеквизитаЗаголовка = ПрефиксШаблон + ШаблонЗаголовка + СтрокаТаблицы.НомерСтроки; 
		ЭтаФорма[ИмяРеквизитаЗаголовка] = СтрокаТаблицы.ЗаголовокТекстовогоБлока;
		ИмяРеквизитаТекстовогоБлока = ПрефиксШаблон + ШаблонТекстовогоБлока + СтрокаТаблицы.НомерСтроки;
		ЭтаФорма[ИмяРеквизитаТекстовогоБлока] = СтрокаТаблицы.Текст;
		
		ПараметрыОтбора = Новый Структура("ИдентификаторТекстовогоБлока", СтрокаТаблицы.ИдентификаторТекстовогоБлока);
		НайденныеСтроки = КартинкиТекстовыхБлоков.НайтиСтроки(ПараметрыОтбора);
		Если НайденныеСтроки.Количество() > 0 Тогда
			ИмяРеквизитаКартинки = ПрефиксШаблон + ШаблонКартинки + СтрокаТаблицы.НомерСтроки;
			ЭтаФорма[ИмяРеквизитаКартинки] = НайденныеСтроки[0].АдресКартинки;
		КонецЕсли;
		
	КонецЦикла;
	
	ШрифтЗаголовка = Новый Шрифт(, 16, Истина);
	ЦветЗаголовка = Новый Цвет(0, 150, 70);
	
	ПорядковыйНомер = 1;
	Для Каждого ИмяЭлементаГруппы Из МассивИменДобавленныхЭлементов Цикл
		
		// Элементы, соответствующие добавленным реквизитам. 
		// Их фиксировать не надо, т.к. при удалении элемента-владельца они удалятся сами.

		ГруппаФормы = Элементы.Найти(ИмяЭлементаГруппы);
				
		ИмяЭлементаЗаголовка = ПрефиксШаблон + ШаблонЗаголовка + ПорядковыйНомер;
		ЭлементЗаголовка = Элементы.Добавить(ИмяЭлементаЗаголовка, Тип("ДекорацияФормы"), ГруппаФормы);
		ЭлементЗаголовка.Вид					= ВидДекорацииФормы.Надпись;
		ЭлементЗаголовка.Заголовок 				= ЭтаФорма[ПрефиксШаблон + ШаблонЗаголовка + ПорядковыйНомер];
		ЭлементЗаголовка.Шрифт 					= ШрифтЗаголовка;
		ЭлементЗаголовка.ЦветТекста 			= ЦветЗаголовка;
		
		// Подгруппа для текста и картинки.
		ИмяЭлементаПодГруппы = ПрефиксШаблон + ПрефиксПодчиненнойГруппы + ШаблонГруппы + ПорядковыйНомер;
		ПодГруппаФормы = Элементы.Добавить(ИмяЭлементаПодГруппы, Тип("ГруппаФормы"), ГруппаФормы);
		ПодГруппаФормы.Вид                        = ВидГруппыФормы.ОбычнаяГруппа;
		ПодГруппаФормы.Отображение                = ОтображениеОбычнойГруппы.Нет;
		ПодГруппаФормы.ОтображатьЗаголовок        = Ложь;
		ПодГруппаФормы.Группировка                = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
		
		ИмяЭлементаТекстовогоБлока = ПрефиксШаблон + ШаблонТекстовогоБлока + ПорядковыйНомер;
		ЭлементТекстовогоБлока = Элементы.Добавить(ИмяЭлементаТекстовогоБлока, Тип("ДекорацияФормы"), ПодГруппаФормы);
		ЭлементТекстовогоБлока.Вид 				= ВидДекорацииФормы.Надпись;
		ЭлементТекстовогоБлока.Заголовок 		= ЭтаФорма[ПрефиксШаблон + ШаблонТекстовогоБлока + ПорядковыйНомер];
		ЭлементТекстовогоБлока.АвтоМаксимальнаяШирина = Ложь;
		ЭлементТекстовогоБлока.Ширина 			= 100;
		
		ИмяЭлементаКартинки = ПрефиксШаблон + ШаблонКартинки + ПорядковыйНомер;
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭтаФорма, ИмяЭлементаКартинки) Тогда
			ПолеКартинки = Элементы.Добавить(ИмяЭлементаКартинки, Тип("ПолеФормы"), ПодГруппаФормы);
			ПолеКартинки.ПутьКДанным 			= ИмяЭлементаКартинки;
			ПолеКартинки.Вид 					= ВидПоляФормы.ПолеКартинки;
			ПолеКартинки.Гиперссылка 			= Истина;
			ПолеКартинки.Масштабировать 		= Истина;
			ПолеКартинки.АвтоМаксимальнаяВысота = Ложь;
			ПолеКартинки.РастягиватьПоВертикали = Истина;
			ПолеКартинки.РазмерКартинки 		= РазмерКартинки.Пропорционально;
			ПолеКартинки.ПоложениеЗаголовка 	= ПоложениеЗаголовкаЭлементаФормы.Нет;
			ПолеКартинки.АвтоМаксимальнаяШирина = Ложь;
			ПолеКартинки.Ширина 				= 20;
			ПолеКартинки.УстановитьДействие("Нажатие", "Подключаемый_ПоказатьКартинку");
			
		КонецЕсли;
			
		ПорядковыйНомер = ПорядковыйНомер + 1;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Асинх Процедура ПоказатьКартинкуАсинх(Элемент)
	
	АдресВоВременномХранилище = ЭтаФорма[Элемент.Имя];
	
	// Расширение файла
	ПараметрыОтбора = Новый Структура("АдресКартинки", АдресВоВременномХранилище);
	НайденныеСтроки = ЭтаФорма.КартинкиТекстовыхБлоков.НайтиСтроки(ПараметрыОтбора);
	РасширениеФайла = НайденныеСтроки[0].РасширениеФайла;
	
	ПутьКФайлу = ПолучитьИмяВременногоФайла(РасширениеФайла);
	Ждать ПолучитьФайлССервераАсинх(АдресВоВременномХранилище, ПутьКФайлу);
	
	Попытка
		
		ЗапуститьПриложениеАсинх(ПутьКФайлу);
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		МенеджерОбработкиОшибок = Новый МенеджерОбработкиОшибок();
		ТекстОшибки = "Не удалось открыть картинку по причине:" + Символы.ПС 
			+ МенеджерОбработкиОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке);
		ПоказатьПредупреждение(, ТекстОшибки);
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки);
			
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура ТаблицаАнкетРеспондента()
	
	ТаблицаАнкет.Очистить();
	
	ПолученнаяТаблицаАнкет = Анкетирование.ТаблицаДоступныхРеспондентуАнкет(Респондент);
	
	Если ПолученнаяТаблицаАнкет <> Неопределено Тогда
		
		Для каждого СтрокаТаблицы Из ПолученнаяТаблицаАнкет Цикл
			
			// {
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТаблицы.АнкетаОпрос, "Основание")
			 И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТаблицы.АнкетаОпрос, "Основание") <> Объект.Ссылка Тогда
				Продолжить;
			КонецЕсли;	
			// }
			
			НоваяСтрока = ТаблицаАнкет.Добавить();
			Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.АнкетаОпрос) Тогда
				
				НоваяСтрока.Представление = СтрокаТаблицы.Статус;
				НоваяСтрока.Статус        = СтрокаТаблицы.Статус;
				
			Иначе
				
				НоваяСтрока.Статус        = СтрокаТаблицы.Статус;
				НоваяСтрока.АнкетаОпрос   = СтрокаТаблицы.АнкетаОпрос;
				НоваяСтрока.Представление = ПолучитьПредставлениеСтрокиДереваАнкеты(СтрокаТаблицы);
				
			КонецЕсли;
			
			НоваяСтрока.КодКартинки = ?(СтрокаТаблицы.Статус = "Опросы",0,1);
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

// Формирует представление строки для дерева анкет.
//
// Параметры:
//  СтрокаДерева  - СтрокаДереваЗначений - на основании ее формируется представление 
//                 анкет и опросов в дереве.
//
&НаСервере
Функция ПолучитьПредставлениеСтрокиДереваАнкеты(СтрокаДерева)
	
	Если ТипЗнч(СтрокаДерева.АнкетаОпрос) = Тип("ДокументСсылка.НазначениеОпросов") Тогда
		Если ЗначениеЗаполнено(СтрокаДерева.ДатаОкончания) Тогда
			Возврат СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = '""%1"", к заполнению до %2'"),
				СтрокаДерева.Наименование, Формат(НачалоДня(КонецДня(СтрокаДерева.ДатаОкончания) + 1), "ДЛФ=D"));
		Иначе	
			Возврат СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = '""%1""'"), СтрокаДерева.Наименование);
		КонецЕсли;
	ИначеЕсли ТипЗнч(СтрокаДерева.АнкетаОпрос) = Тип("ДокументСсылка.Анкета") Тогда
		Если ЗначениеЗаполнено(СтрокаДерева.ДатаАнкеты) И ЗначениеЗаполнено(СтрокаДерева.ДатаОкончания) Тогда
			Возврат СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = '""%1"", последний раз редактировали %2, к заполнению до %3'"), 
				СтрокаДерева.Наименование, Формат(СтрокаДерева.ДатаАнкеты, "ДЛФ=D"),
				Формат(НачалоДня(КонецДня(СтрокаДерева.ДатаОкончания) + 1), "ДЛФ=D"));
		ИначеЕсли ЗначениеЗаполнено(СтрокаДерева.ДатаАнкеты) Тогда
			Возврат СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = '""%1"", последний раз редактировали %2'"), 
				СтрокаДерева.Наименование, Формат(СтрокаДерева.ДатаАнкеты, "ДЛФ=D"));
		Иначе
			Возврат СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = '""%1""'"), СтрокаДерева.Наименование);
		КонецЕсли;
	КонецЕсли;
	Возврат "";
	
КонецФункции

&НаСервере
Процедура УстановитьДоступностьЭлементовНаОснованииПрогрессаВыполненияКурса()
	
	Если Объект.Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	ПустаяСтрока = "";
	ФорматДаты = "ДЛФ=DDT";
	
	ДанныеПрохожденияКурса = ПолучитьДанныеПрохожденияКурсаРеспондентом(Объект.Ссылка, Респондент);
	
	Элементы.ДекорацияДатаОзнакомления.Заголовок = ПустаяСтрока;
	Элементы.ДекорацияДатаВыполнения.Заголовок = ПустаяСтрока;
	
	Если ЗначениеЗаполнено(ДанныеПрохожденияКурса.ДатаОзнакомленияСТеорией) Тогда
		Элементы.ПодтвердитьОзнакомление.Пометка = Истина;
		Элементы.ПодтвердитьОзнакомление.Доступность = Ложь;
		Элементы.ДекорацияДатаОзнакомления.Заголовок = Формат(ДанныеПрохожденияКурса.ДатаОзнакомленияСТеорией, ФорматДаты);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеПрохожденияКурса.ДатаВыполненияПрактическойЧасти) Тогда
		Элементы.ПодтвердитьВыполнениеКурса.Пометка = Истина;
		Элементы.ГруппаПрактикаДляОбучающихся.Доступность = Ложь;
		Элементы.ДекорацияДатаВыполнения.Заголовок = Формат(ДанныеПрохожденияКурса.ДатаВыполненияПрактическойЧасти, ФорматДаты);
	КонецЕсли;
	
	Если Объект.КомментарийОбучающегосяОбязателен = Истина Тогда
		Элементы.КомментарийОбучающегося.АвтоОтметкаНезаполненного = Истина;
	КонецЕсли;
	
	КомментарийОбучающегося = ДанныеПрохожденияКурса.Комментарий;
	
	Элементы.ГруппаДекорацияКурсПройден.Видимость = ЗначениеЗаполнено(ДанныеПрохожденияКурса.ДатаОзнакомленияСТеорией)
		И ЗначениеЗаполнено(ДанныеПрохожденияКурса.ДатаВыполненияПрактическойЧасти);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьДанныеПрохожденияКурсаРеспондентом(КурсОбучения, Респондент)
	
	Регистр = РегистрыСведений.ДанныеРеспондентовКурсовОбучения;
	Возврат Регистр.ПолучитьДанныеПрохожденияКурсаРеспондентом(КурсОбучения, Респондент);
	
КонецФункции

&НаСервере
Процедура ПодтвердитьОзнакомлениеНаСервере()

	УстановитьДатуОзнакомленияРеспондентаСКурсом(Объект.Ссылка, Респондент);
	УстановитьДоступностьЭлементовНаОснованииПрогрессаВыполненияКурса();
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьДатуОзнакомленияРеспондентаСКурсом(КурсОбучения, Респондент)

	Регистр = РегистрыСведений.ДанныеРеспондентовКурсовОбучения;
	Регистр.УстановитьДатуОзнакомленияРеспондентаСКурсом(КурсОбучения, Респондент);
	
КонецПроцедуры

&НаСервере
Процедура ПодтвердитьВыполнениеКурсаНаСервере()
	
	УстановитьДатуВыполненияКурсаРеспондентом(Объект.Ссылка, Респондент, КомментарийОбучающегося);
	УстановитьДоступностьЭлементовНаОснованииПрогрессаВыполненияКурса();
	УведомитьАвтораКурсаОВыполненииСПомощьюЗадания();
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьДатуВыполненияКурсаРеспондентом(КурсОбучения, Респондент, КомментарийРеспондента)
	
	Регистр = РегистрыСведений.ДанныеРеспондентовКурсовОбучения;
	Регистр.УстановитьДатуВыполненияКурсаРеспондентом(КурсОбучения, Респондент, КомментарийРеспондента);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеНажатияНаУведомлениеОбУспешномОзнакомленииСТеорией(Результат) Экспорт
	Элементы.ГруппаКурсДляОбучающихсяСтраницы.ТекущаяСтраница = Элементы.ГруппаТеорияДляОбучающихсяСтраница;
КонецПроцедуры

&НаКлиенте
Процедура ПослеНажатияНаУведомлениеОВыполненииКурса(Результат) Экспорт
	Закрыть();
КонецПроцедуры

&НаСервере
Процедура УведомитьАвтораКурсаОВыполненииСПомощьюЗадания()
	
	Возврат;
	
КонецПроцедуры

